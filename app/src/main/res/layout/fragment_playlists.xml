<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/media_playlists"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.media.fragment.PlaylistsFragment">

    <Button
        android:id="@+id/playlists_add_new_playlist_btn"
        style="@style/Search_functional_button"
        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:layout_marginVertical="@dimen/big_padding"
        android:text="@string/media_new_playlist"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/playlists_placeholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:constraint_referenced_ids="playlists_placeholder_text, playlists_placeholder_image" />

    <ImageView
        android:id="@+id/playlists_placeholder_image"

        android:layout_width="120dp"
        android:layout_height="120dp"

        android:src="@drawable/no_tracks_found_placeholder"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        app:layout_constraintVertical_bias="0.2" />

    <TextView
        android:id="@+id/playlists_placeholder_text"

        style="@style/Search_placeholder_text_style"
        android:layout_width="wrap_content"

        android:layout_height="wrap_content"
        android:layout_margin="@dimen/normal_padding"

        android:text="@string/media_no_playlist_found"
        android:textAlignment="center"
        android:textColor="?attr/colorOnSecondary"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/playlists_placeholder_image" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlists_recycle_view"
        android:layout_marginTop="@dimen/normal_padding"
        android:layout_width="0dp"
        android:layout_height="0dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/playlists_add_new_playlist_btn"

        tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        tools:listitem="@layout/playlist"
        tools:spanCount="2" />
</androidx.constraintlayout.widget.ConstraintLayout>