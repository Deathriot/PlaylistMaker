<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/audio_player"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="?attr/colorOnSecondary"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/audio_player_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="?attr/colorSecondary"
        tools:context=".ui.audio_player.fragment.AudioPlayerFragment">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/left_border"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.077" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/right_border"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.923" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/player_left_track_info_border"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="right"
            app:constraint_referenced_tags="duration_name_tag,
        collection_name_tag, release_year_name_tag, genre_name_tag, country_name_tag" />

        <ImageView
            android:id="@+id/player_back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="@dimen/normal_padding"
            android:src="@drawable/arrow_back_24x24"
            app:layout_constraintStart_toEndOf="@id/left_border"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/player_track_cover"
            android:layout_width="0dp"
            android:layout_height="0dp"

            android:scaleType="centerCrop"

            app:layout_constraintDimensionRatio="h,1:1"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintStart_toEndOf="@id/left_border"
            app:layout_constraintTop_toBottomOf="@id/player_back_button"

            tools:src="@drawable/ic_placeholder_45" />

        <TextView
            android:id="@+id/player_track_title"
            style="@style/Medium_text_style"

            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/big_padding"
            android:ellipsize="end"
            android:maxLines="1"

            android:textColor="?attr/colorOnSecondary"
            android:textFontWeight="400"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintStart_toEndOf="@id/left_border"
            app:layout_constraintTop_toBottomOf="@id/player_track_cover"

            tools:text="Yesterday (Remastered 2009)" />

        <TextView
            android:id="@+id/player_track_artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/ys_display_medium"

            android:maxLines="1"
            android:paddingVertical="@dimen/mini_padding"

            android:textColor="?attr/colorOnSecondary"
            android:textFontWeight="400"
            android:textSize="@dimen/text_size_14"

            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintStart_toEndOf="@id/left_border"
            app:layout_constraintTop_toBottomOf="@id/player_track_title"

            tools:text="The Beatles" />

        <com.example.playlistmaker.ui.audio_player.views.PlaybackButtonView
            android:id="@+id/player_play_btn"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:enabled="false"

            app:layout_constraintBottom_toTopOf="@id/player_track_duration_name"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/player_track_artist"
            app:layout_constraintVertical_bias="0.35"

            app:imagePause="@drawable/ic_audio_player_pause_btn_83"
            app:imagePlay="@drawable/ic_audio_player_play_btn_83"/>


        <ImageButton
            android:id="@+id/player_add_playlist_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:background="@drawable/ic_audio_player_add_playlist_btn_51"

            app:layout_constraintBottom_toBottomOf="@id/player_play_btn"
            app:layout_constraintStart_toEndOf="@id/left_border"
            app:layout_constraintTop_toTopOf="@id/player_play_btn" />

        <ImageView
            android:id="@+id/player_like_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:src="@drawable/ic_audio_player_inactive_like_btn_51"

            app:layout_constraintBottom_toBottomOf="@id/player_play_btn"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintTop_toTopOf="@id/player_play_btn" />

        <TextView
            android:id="@+id/player_track_current_time"
            style="Func_button_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginTop="@dimen/minor_padding"
            android:textColor="?attr/colorOnSecondary"
            app:layout_constraintEnd_toStartOf="@id/right_border"

            app:layout_constraintStart_toEndOf="@id/left_border"

            app:layout_constraintTop_toBottomOf="@id/player_play_btn"

            tools:text="3:43" />

        <TextView
            android:id="@+id/player_track_duration"

            style="@style/Audio_player_track_info_text_style"
            android:layout_width="0dp"

            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSecondary"

            app:layout_constraintBaseline_toBaselineOf="@id/player_track_duration_name"
            app:layout_constraintEnd_toStartOf="@id/right_border"

            tools:text="6:45" />

        <TextView
            android:id="@+id/player_track_duration_name"
            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginVertical="@dimen/normal_padding"
            android:text="@string/player_duration"
            android:textColor="@color/gray"

            app:layout_constraintBottom_toTopOf="@id/player_track_collection_name"
            app:layout_constraintStart_toEndOf="@id/left_border"

            app:layout_constraintTag="duration_name_tag" />

        <TextView
            android:id="@+id/player_track_collection_name"
            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginVertical="@dimen/normal_padding"

            android:text="@string/player_collection"
            android:textColor="@color/gray"

            app:layout_constraintBottom_toTopOf="@id/player_release_year_name"
            app:layout_constraintStart_toEndOf="@id/left_border"

            app:layout_constraintTag="collection_name_tag" />

        <TextView
            android:id="@+id/player_track_collection"
            style="@style/Audio_player_track_info_text_style"
            android:layout_width="0dp"

            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAlignment="textEnd"
            android:textColor="?attr/colorOnSecondary"

            app:layout_constraintBaseline_toBaselineOf="@id/player_track_collection_name"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintStart_toEndOf="@id/player_left_track_info_border"
            app:layout_constraintTop_toBottomOf="@id/player_track_duration"

            tools:text="Yesterday (Remastered 2009)" />

        <TextView
            android:id="@+id/player_release_year_name"
            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/normal_padding"

            android:text="@string/player_year"
            android:textColor="@color/gray"

            app:layout_constraintBottom_toTopOf="@id/player_genre_name"
            app:layout_constraintStart_toEndOf="@id/left_border"

            app:layout_constraintTag="release_year_name_tag" />

        <TextView
            android:id="@+id/player_genre_name"
            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginVertical="@dimen/normal_padding"
            android:text="@string/player_genre"
            android:textColor="@color/gray"

            app:layout_constraintBottom_toTopOf="@id/player_country_name"
            app:layout_constraintStart_toEndOf="@id/left_border"
            app:layout_constraintTag="genre_name_tag" />

        <TextView
            android:id="@+id/player_country_name"
            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/normal_padding"

            android:text="@string/player_country"
            android:textColor="@color/gray"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/left_border"

            app:layout_constraintTag="country_name_tag" />

        <TextView
            android:id="@+id/player_release_year"

            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"

            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSecondary"

            app:layout_constraintBaseline_toBaselineOf="@id/player_release_year_name"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintTop_toBottomOf="@id/player_track_collection"

            tools:text="1965" />

        <TextView
            android:id="@+id/player_genre"

            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"

            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSecondary"

            app:layout_constraintBaseline_toBaselineOf="@id/player_genre_name"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintTop_toBottomOf="@id/player_release_year"

            tools:text="Rock" />

        <TextView
            android:id="@+id/player_country"

            style="@style/Audio_player_track_info_text_style"
            android:layout_width="wrap_content"

            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSecondary"

            app:layout_constraintBaseline_toBaselineOf="@id/player_country_name"
            app:layout_constraintEnd_toStartOf="@id/right_border"
            app:layout_constraintTop_toBottomOf="@id/player_genre"

            tools:text="Великобритания" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/player_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/player_bottom_sheet"

        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/player_bottom_sheet_bg"
        android:orientation="vertical"
        android:visibility="visible"
        app:behavior_hideable="true"
        app:behavior_peekHeight="505dp"
        tools:visibility="gone"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/minor_padding"
            android:src="@drawable/audio_player_bottom_sheet_top_decoration" />

        <TextView
            android:id="@+id/player_bottom_sheet_title"
            style="@style/Player_bottom_sheet_title_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginVertical="@dimen/big_padding"
            android:text="@string/player_bottom_sheet_add_playlist"
            android:textColor="?attr/colorOnSecondary" />

        <Button
            android:id="@+id/player_bottom_sheet_add_playlist"
            style="@style/Func_button_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"

            android:backgroundTint="?attr/colorOnSecondary"
            android:paddingVertical="@dimen/padding_12"
            android:text="@string/player_bottom_sheet_new_playlist_btn"
            android:textAllCaps="false"
            android:textColor="?attr/colorSecondary"
            app:cornerRadius="@dimen/button_radius_54" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/player_bottom_sheet_recycle_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="@dimen/normal_padding"
            android:layout_marginTop="@dimen/normal_padding"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:itemCount="5"
            tools:visibility="gone"
            tools:listitem="@layout/player_playlist_bottom_sheet" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>